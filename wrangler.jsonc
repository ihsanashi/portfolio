{
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "portfolio",
  "compatibility_date": "2026-04-21",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "ahmadihsan.com",
      "custom_domain": true,
    },
  ],
  "preview_urls": true,
  "workers_dev": true,
}
